		&u.Name,
		&u.Email,
		&u.OAuthID,
		&u.OAuthProvider,
		&u.CreatedAt,
		&u.UpdatedAt,
	)
	if err != nil {
		if errors.Is(err, pgx.ErrNoRows) {
			return nil, definitions.ErrUserNotFound
		}
		return nil, err
	}
	return &u, nil
}

func scanUsers(rows pgx.Rows) ([]entity.User, error) {
	var users []entity.User
	for rows.Next() {
		var u entity.User
		err := rows.Scan(
			&u.ID,
			&u.Name,
			&u.Email,
			&u.OAuthID,
			&u.OAuthProvider,
			&u.CreatedAt,
			&u.UpdatedAt,
		)
		if err != nil {
			return nil, err
		}
		users = append(users, u)
	}
	return users, nil
