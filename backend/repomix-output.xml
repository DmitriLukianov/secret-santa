<file path="docker-compose.yaml">
services:
  postgres:
    image: postgres:18.3-bookworm
    container_name: santa_postgres
    restart: always
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    ports:
      - "5432:5432"
    volumes:
      - ${PROJECT_ROOT}/out/pgdata:/var/lib/postgresql

  migrate:
    image: migrate/migrate:v4.19.1
    container_name: santa_migrate
    volumes:
      - ${PROJECT_ROOT}/migrations:/migrations
</file>

