func UsersToResponse(users []entity.User) []UserResponse {
	if users == nil {
		return nil
	}

	resp := make([]UserResponse, len(users))
	for i, u := range users {
		resp[i] = UserToResponse(&u)
	}
	return resp
}

func ParticipantToResponse(p *entity.Participant) ParticipantResponse {
	if p == nil {
		return ParticipantResponse{}
	}
	return ParticipantResponse{
