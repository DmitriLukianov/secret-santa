	if input.Title != nil {
		q = q.Set("title", *input.Title)
	}
	if input.Description != nil {
		q = q.Set("description", *input.Description)
	}
	if input.Rules != nil {
		q = q.Set("rules", *input.Rules)
	}
	if input.Recommendations != nil {
