# Приложение
APP_ENV=local
APP_PORT=8080
LOG_LEVEL=info
APP_BASE_URL=
FRONTEND_URL=

# База данных (для docker-compose)
POSTGRES_USER=santa
POSTGRES_PASSWORD=
POSTGRES_DB=secretsanta

# База данных (для бэкенда)
DATABASE_URL=postgres://santa:12345@localhost:5432/secretsanta?sslmode=disable

# JWT (минимум 32 символа)
JWT_SECRET=
JWT_TTL=24h

# SMTP (необязательно — без него email просто не отправляется)
SMTP_HOST=smtp.mail.ru
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=

# GitHub OAuth (необязательно)
OAUTH_PROVIDER=github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=
